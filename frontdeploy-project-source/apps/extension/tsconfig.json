{
  "extends": "plasmo/templates/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~*": [
        "./src/*"
      ]
    },
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  },
  "include": [
    ".plasmo/index.d.ts",
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build"
  ]
}
