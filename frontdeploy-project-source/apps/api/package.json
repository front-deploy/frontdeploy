{
  "name": "@axiom-intelligence/api",
  "version": "0.1.0",
  "description": "Read-only intelligence API for Frontdeploy.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test test/**/*.test.ts",
    "start": "node dist/server.js",
    "audit:runtime": "npm audit --omit=dev --audit-level=moderate",
    "verify": "npm run typecheck && npm run test && npm run build && npm run audit:runtime"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "pg": "^8.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
