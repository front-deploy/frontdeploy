// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ------------------------------------
// KOL Alerts (Phase 4)
// ------------------------------------

model Watchlist {
  id        String   @id @default(uuid())
  handle    String   @unique
  userId    String   @unique // Numeric string ID from X
  tier      String   // "A", "B", "C", "D"
  category  String?  @default("kol") // "kol", "news"
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("frontdeploy_watchlist")
}

model KolEvent {
  id              String   @id @default(uuid())
  tweetId         String   @unique
  authorHandle    String
  authorUserId    String
  text            String
  url             String
  isSignal        Boolean  @default(false)
  contractAddress String?
  ticker          String?
  category        String?  @default("kol")
  postedAt        DateTime
  createdAt       DateTime @default(now())

  @@map("frontdeploy_kol_event")
}

// ------------------------------------
// Smart Followers (Phase 5)
// ------------------------------------

model SmartAccount {
  id            String   @id @default(uuid())
  handle        String   @unique
  userId        String?  @unique // Numeric string ID from X
  category      String?  // e.g., "tier-A", "whale", "dev"
  followerCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  mappings      SmartFollowerMapping[]

  @@map("frontdeploy_smart_account")
}

model SmartFollowerMapping {
  id             String   @id @default(uuid())
  targetHandle   String   // The account being followed
  smartAccountId String
  detectedAt     DateTime @default(now())

  smartAccount   SmartAccount @relation(fields: [smartAccountId], references: [id], onDelete: Cascade)

  @@unique([targetHandle, smartAccountId])
  @@index([targetHandle])
  @@map("frontdeploy_smart_follower_mapping")
}

// ------------------------------------
// Finance / Treasury (Phase X)
// ------------------------------------

model BurnHistory {
  id          String   @id @default(uuid())
  solSpent    Float
  fdpBought   Float?
  fdpBurned   Float
  txHash      String   @unique
  createdAt   DateTime @default(now())

  @@map("frontdeploy_burn_history")
}

// ------------------------------------
// Pro Features / Deployer Intel
// ------------------------------------

model DeployerHistory {
  id              String   @id @default(uuid())
  walletAddress   String   @unique
  totalLaunches   Int      @default(0)
  ruggedLaunches  Int      @default(0)
  walletAgeDays   Int      @default(0)
  riskScore       Int      @default(50)
  riskLevel       String   @default("watch")
  fundingSource   String?  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("frontdeploy_deployer_history")
}

// ------------------------------------
// Users & Roles
// ------------------------------------

model User {
  id               String    @id @default(uuid())
  walletAddress    String    @unique
  isFoundingMember Boolean   @default(false)
  enrolledAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("frontdeploy_user")
}

// ------------------------------------
// Pro Features / Account History
// ------------------------------------

model XIdentitySnapshot {
  id           String   @id @default(uuid())
  handle       String
  xUserId      String   @map("x_user_id")
  displayName  String
  bio          String
  avatarUrl    String
  ts           DateTime @default(now())

  @@index([xUserId])
  @@index([handle])
  @@map("frontdeploy_x_identity_snapshots")
}

